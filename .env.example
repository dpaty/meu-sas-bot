# 🔑 CONFIGURAÇÃO DE AMBIENTE - SaaS Profissional

# ================== GEMINI API ==================
# Chave Master que será usada para TODOS os clientes
# Obtenha em: https://ai.google.dev/gemini-api
MASTER_GEMINI_KEY=gsk_sua_chave_super_secreta_aqui

# ================== SERVIDOR ==================
PORT=3000
NODE_ENV=production

# ================== WHATSAPP ==================
# Configurações do WhatsApp Business API (se usar)
WHATSAPP_API_URL=https://graph.instagram.com/v18.0
WHATSAPP_BUSINESS_ACCOUNT_ID=seu_account_id
WHATSAPP_PHONE_NUMBER_ID=seu_phone_id

# ================== BANCO DE DADOS ==================
# SQLite é usado localmente (database.sqlite)
DATABASE_PATH=./database.sqlite

# ================== LOGS ==================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ================== SEGURANÇA ==================
# JWT Secret para autenticação do Dashboard
JWT_SECRET=seu_secret_jwt_super_secreto_aqui

# ================== INTEGRAÇÃO PAGAMENTO (Opcional) ==================
# STRIPE_SECRET_KEY=sk_live_xxx
# PAGSEGURO_TOKEN=token_xxx

# ================== DEBUG ==================
# Defina como true para logs detalhados no desenvolvimento
DEBUG=false
